# ============================================================================
# Price Is Right — Environment Configuration Template
# ============================================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.
# ============================================================================

# ---------------------------------------------------------------------------
# OpenAI API (required for Scanner Agent and Frontier Agent)
# ---------------------------------------------------------------------------
OPENAI_API_KEY=sk-your-openai-api-key-here

# ---------------------------------------------------------------------------
# Anthropic API (required for Messaging Agent — Claude message crafting)
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here

# ---------------------------------------------------------------------------
# Pushover Push Notifications (required for deal alerts)
# Get your keys at: https://pushover.net/
# ---------------------------------------------------------------------------
PUSHOVER_USER=your-pushover-user-key
PUSHOVER_TOKEN=your-pushover-app-token

# ---------------------------------------------------------------------------
# Modal (optional — for fine-tuned Specialist Agent)
# Set up at: https://modal.com/
# ---------------------------------------------------------------------------
# MODAL_TOKEN_ID=your-modal-token-id
# MODAL_TOKEN_SECRET=your-modal-token-secret

# ---------------------------------------------------------------------------
# Application Configuration
# ---------------------------------------------------------------------------
# Minimum discount (USD) to trigger a push notification
DEAL_THRESHOLD=50

# ChromaDB vector store path (inside container)
CHROMA_DB_PATH=products_vectorstore

# Memory file path (inside container)
MEMORY_FILE=data/memory.json

# Dashboard port
DASHBOARD_PORT=7860

# API port
API_PORT=8000

# ---------------------------------------------------------------------------
# Preprocessor Model (optional — defaults to gpt-4o-mini)
# ---------------------------------------------------------------------------
# PRICER_PREPROCESSOR_MODEL=gpt-4o-mini
# PRICER_PREPROCESSOR_MODEL=ollama/llama3.2

# ---------------------------------------------------------------------------
# Ollama (optional — for local LLM preprocessing)
# ---------------------------------------------------------------------------
# OLLAMA_BASE_URL=http://localhost:11434

# ---------------------------------------------------------------------------
# RSS Feed Configuration (optional — overrides default DealNews feeds)
# Comma-separated list of RSS feed URLs
# ---------------------------------------------------------------------------
# RSS_FEED_URLS=https://www.dealnews.com/c142/Electronics/?rss=1,https://www.dealnews.com/c39/Computers/?rss=1

# ---------------------------------------------------------------------------
# Specialist Agent Local Endpoint (optional — fallback if Modal is unavailable)
# ---------------------------------------------------------------------------
# SPECIALIST_LOCAL_ENDPOINT=http://localhost:8080/price

# ---------------------------------------------------------------------------
# Neural Network Weights Path (optional)
# ---------------------------------------------------------------------------
# DNN_WEIGHTS_PATH=data/deep_neural_network.pth
